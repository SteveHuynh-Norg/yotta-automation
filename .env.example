# Optional: restrict a run to a single configured site by key (see config/sites.ts).
# Leave empty to run against all enabled sites.
SITE=selleys

# Optional: override the base URL of the primary site without editing config.
# BASE_URL=https://directory.selleys.com.au/

# Link checking tuning
LINK_CHECK_CONCURRENCY=8
LINK_CHECK_TIMEOUT_MS=15000

# Set to "true" to expand pages-under-test from the site's sitemap.xml
# (heavier run — checks far more pages). Default uses the curated sample.
USE_SITEMAP=false

# When USE_SITEMAP=true, cap how many sitemap URLs to test (0 = no cap).
SITEMAP_LIMIT=25
