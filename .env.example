# Optional: restrict a run to a single configured site by key (see config/sites.ts).
# Leave empty to run against all enabled sites.
SITE=selleys

# Optional: override the base URL of the primary site without editing config.
# BASE_URL=https://directory.selleys.com.au/

# Link checking tuning
# Concurrency is kept low so bursts don't trip the site's CDN/WAF rate limiter
# (which returns 429s — those are retried with backoff, not counted as broken).
LINK_CHECK_CONCURRENCY=4
LINK_CHECK_TIMEOUT_MS=15000
LINK_CHECK_MAX_RETRIES=3

# Set to "true" to expand pages-under-test from the site's sitemap.xml
# (heavier run — checks far more pages). Default uses the curated sample.
USE_SITEMAP=false

# When USE_SITEMAP=true, cap how many sitemap URLs to test (0 = no cap).
SITEMAP_LIMIT=25

# --- Form-submission suite (npm run test:forms) -----------------------------

# Shared HMAC secret for the reCAPTCHA QA bypass URL. Value is supplied by the
# developer's qa-bypass-url.sh — keep it out of git (this .env is gitignored)
# and store it as the QA_BYPASS_SECRET GitHub Actions secret for CI.
QA_BYPASS_SECRET=

# Static token sent as the `X-QA-Bypass` request header on every browser request,
# to get the automated browser past Cloudflare Bot Fight Mode on the BND zones
# that 403 otherwise (supplied by the developer). Harmless on sites that don't
# look for it. Keep out of git and store as the QA_BYPASS_HEADER Actions secret.
QA_BYPASS_HEADER=

# Optional: restrict a run to a single configured form by key (see config/forms.ts).
# FORM=ssdoors

# Optional: override the form page URL without editing config.
# FORM_URL=https://ssdoors.com.au/contact-us/

# --- Slack notifications (run summary) --------------------------------------

# Slack Incoming Webhook URL. When set, a run summary is posted to the channel;
# when empty, the Slack reporter is a no-op. This is a SECRET — keep it out of
# git (this .env is gitignored) and store it as the SLACK_WEBHOOK_URL GitHub
# Actions secret for CI.
SLACK_WEBHOOK_URL=

# Optional: 'always' (default) posts on every run; 'failure' posts only when
# there are failed or flaky tests.
# SLACK_NOTIFY_ON=always
